# ============================================================================
#  Polymarket near-certainty bot — environment configuration
#  Copy to `.env` and fill in. NEVER commit the real .env to git.
# ============================================================================

# ─── SAFETY ─────────────────────────────────────────────────────────────────
# Default TRUE. Flip to false ONLY after you've watched a few dry-run cycles
# and are happy with what it would have bet.
DRY_RUN=true
REQUIRE_CONFIRM=true

# ─── WALLET (required for live trading) ─────────────────────────────────────
# Polygon private key of the wallet that holds your USDC.e. Hex, no 0x.
POLYMARKET_PRIVATE_KEY=

# Funder address: the address that actually holds the USDC.
#   - Email/Magic-link Polymarket account → this is your Polymarket "proxy"
#     deposit address shown in the UI under Deposit → Polygon.
#   - EOA / MetaMask → same as the address derived from PRIVATE_KEY (can leave blank).
POLYMARKET_FUNDER_ADDRESS=

# Signature type:
#   1 = email / Magic-link wallet (most Polymarket UI users)  ← default
#   0 = EOA / MetaMask / hardware wallet
POLYMARKET_SIGNATURE_TYPE=1

# ─── TELEGRAM ALERTS (optional) ─────────────────────────────────────────────
# Leave blank to disable. With both set, bot pings on each order + errors.
# How to get them:
#   1. Telegram → @BotFather → /newbot → copy token
#   2. Message your new bot "hi", then open:
#      https://api.telegram.org/bot<TOKEN>/getUpdates → find chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── PROXY (required for Render/US/EU hosts) ──────────────────────────────
# Polymarket geoblocks POST /order from US & EU datacenter IPs. Set this
# only if you're hosting on Render/AWS/GCP/Azure. Leave blank if running
# from an already-allowed region (Hetzner Helsinki, your own machine, etc.).
# Format: http://user:pass@host:port
CLOB_PROXY_URL=

# ─── STRATEGY ───────────────────────────────────────────────────────────────
MAX_ASK=0.95
# Bid must be near 100¢ too — filters out cheap long-shots with no consensus.
MIN_BID=0.90
# Skip pathologically wide books.
MAX_SPREAD=0.05
HAIRCUT=0.01
MIN_EDGE=0.04
MIN_VOLUME_USD=50000
MIN_LIQUIDITY_USD=5000
MAX_DAYS_TO_RESOLUTION=14
MIN_DAYS_TO_RESOLUTION=0.5
# Edge floor scales to this annualized target: longer bets need more edge.
TARGET_APR=1.0

# ─── SPORTS ─────────────────────────────────────────────────────────────────
# Only bet sports markets after tip-off / first pitch / kickoff. Pre-game
# favorites can lose to late scratches, weather, lineup changes.
SPORTS_REQUIRE_GAME_STARTED=true

# Comma-separated event/market slugs to ALWAYS fetch directly (for markets
# Polymarket hides from bulk listings). Leave blank unless you know of one.
WATCHLIST_SLUGS=

# ─── SIZING ─────────────────────────────────────────────────────────────────
BANKROLL_USD=1000
KELLY_FRACTION=0.25
MAX_POSITIONS=20
MAX_PER_MARKET_USD=200
MAX_PCT_OF_BOOK=0.20
MIN_ORDER_USD=5
# Hard cap any single position to this fraction of live NAV (cash + open
# positions). Protects against Kelly going huge on a single "sure thing".
MAX_PCT_OF_NAV=0.15

# ─── STRATEGY FILTERS (v2 — derived from loser analysis) ────────────────────
# BTC threshold buffer: skip BTC>$X markets where spot is within N% of strike.
# Daily BTC sigma ≈ 2.5%, so 5% ≈ 2-sigma cushion.
BTC_FILTER_ENABLED=true
MIN_BTC_BUFFER_PCT=0.05

# Max concurrent positions sharing the same parent event_slug (prevents
# correlated stacks like Elon-tweet ranges or sports series double-counts).
MAX_POSITIONS_PER_EVENT=2

# Per-category edge floors. Empty → fall back to MIN_EDGE. Higher floor for
# higher-vol categories (crypto/oil).
MIN_EDGE_CRYPTO=0.06
MIN_EDGE_OIL=0.06

# ─── RUNTIME ────────────────────────────────────────────────────────────────
POLL_SECONDS=60
LOG_DIR=logs
STATE_FILE=logs/state.json

# ─── STOP LOSS (smart, EV-aware) ────────────────────────────────────────────
# Per-position stop. Fires only if ALL three triggers hit:
#   1. Drawdown ≥ entry edge (e.g. entered at 0.91 with 0.08 edge → stop at 0.83)
#   2. Recent move ≥ STOP_VOL_SIGMA σ of last 6h price history
#   3. Velocity: price dropped ≥ STOP_VELOCITY_PCT in the last 60 min
#      (sustained drop, not a single tick wobble)
# When triggered: market-sell immediately, log to logs/stop_exits.jsonl,
# Telegram alert, 24h cooldown to avoid re-entry.
STOP_LOSS_ENABLED=true
STOP_VOL_SIGMA=2.0
STOP_VELOCITY_PCT=0.03
STOP_MIN_HOLD_MINUTES=5
STOP_MIN_HOURS_TO_CLOSE=12
STOP_COOLDOWN_HOURS=24

# ─── AUTO-REDEEM (Stage 2) ──────────────────────────────────────────────────
# Generate at polymarket.com → Settings → API. Required for redeemer.py.
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=
