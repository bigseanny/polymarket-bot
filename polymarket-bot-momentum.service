[Unit]
Description=Polymarket momentum bot (STRATEGY_MODE=momentum)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=bot
Group=bot
WorkingDirectory=/home/bot/polymarket-bot-momentum
EnvironmentFile=/home/bot/polymarket-bot-momentum/.env
ExecStart=/home/bot/polymarket-bot-momentum/.venv/bin/python /home/bot/polymarket-bot-momentum/bot.py
Restart=always
RestartSec=10
StandardOutput=append:/home/bot/polymarket-bot-momentum/logs/bot.log
StandardError=append:/home/bot/polymarket-bot-momentum/logs/bot.log

[Install]
WantedBy=multi-user.target
